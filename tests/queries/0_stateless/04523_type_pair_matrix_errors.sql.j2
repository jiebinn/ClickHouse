-- Tags: long
-- Tagged `long` because the throwing wide-integer (Int256/UInt256) divisions and Decimal
-- scale conversions in this file are ~1000x slower under sanitizers, which pushes a single
-- run over the flaky-check per-test time limit even though it is ~0.2s on a release build.
--
-- Exceptional cases of comparison and arithmetic over mixed type pairs involving
-- Decimal and 128/256-bit integers. Companion of 04513_type_pair_matrix_comparison
-- and 04514_type_pair_matrix_arithmetic, which cover the non-throwing matrix.
--
-- This file covers comparison overflow during Decimal scale conversion and integer division
-- by zero; 04520_type_pair_matrix_division_overflow_errors covers division overflow of the most
-- negative value and unsupported type-pair combinations. The two files are split only to fit
-- each within the flaky-check per-run time budget.
--
-- Every throwing case is exercised in all four constness shapes: vector/vector, left-const,
-- right-const, and both-const. DecimalComparison::applyMixed and FunctionBinaryArithmetic have
-- distinct executor branches per constness (and modulo/moduloLegacy route a right-constant
-- divisor through ModuloByConstantImpl::vectorConstant with its own zero and lowest() checks),
-- so a regression on the constant side would be missed by the vector/vector shape alone. The
-- both-const shape uses identity(...) so the analyzer does not fold the expression away before
-- the executor runs.

-- A throwing infix comparison "a <op> b" in all four constness shapes.
{% macro cmp_throws(a, op, b, err) -%}
SELECT materialize({{ a }}) {{ op }} materialize({{ b }}); -- { serverError {{ err }} }
SELECT {{ a }} {{ op }} materialize({{ b }}); -- { serverError {{ err }} }
SELECT materialize({{ a }}) {{ op }} {{ b }}; -- { serverError {{ err }} }
SELECT identity({{ a }}) {{ op }} identity({{ b }}); -- { serverError {{ err }} }
{%- endmacro %}

-- A throwing function call "fn(a, b)" in all four constness shapes.
{% macro fn_throws(fn, a, b, err) -%}
SELECT {{ fn }}(materialize({{ a }}), materialize({{ b }})); -- { serverError {{ err }} }
SELECT {{ fn }}({{ a }}, materialize({{ b }})); -- { serverError {{ err }} }
SELECT {{ fn }}(materialize({{ a }}), {{ b }}); -- { serverError {{ err }} }
SELECT {{ fn }}(identity({{ a }}), identity({{ b }})); -- { serverError {{ err }} }
{%- endmacro %}

SELECT '-- comparison overflow during scale conversion';
{{ cmp_throws("CAST('18446744073709551615', 'UInt64')", '>', "toDecimal32('1.5', 2)", 'DECIMAL_OVERFLOW') }}
{{ cmp_throws("toUInt64(9223372036854775807)", '>', "toDecimal64('1.5', 4)", 'DECIMAL_OVERFLOW') }}
{{ cmp_throws("toDecimal32('1.5', 2)", '=', "CAST('115792089237316195423570985008687907853269984665640564039457584007913129639935', 'UInt256')", 'DECIMAL_OVERFLOW') }}

SELECT '-- the same comparisons with the overflow check disabled';
SELECT materialize(CAST('18446744073709551615', 'UInt64')) > materialize(toDecimal32('1.5', 2)) SETTINGS decimal_check_overflow = 0;
SELECT materialize(toUInt64(9223372036854775807)) > materialize(toDecimal64('1.5', 4)) SETTINGS decimal_check_overflow = 0;
SELECT materialize(toDecimal32('1.5', 2)) = materialize(CAST('115792089237316195423570985008687907853269984665640564039457584007913129639935', 'UInt256')) SETTINGS decimal_check_overflow = 0;

SELECT '-- extreme values that must compare without overflow';
SELECT materialize(CAST('-170141183460469231731687303715884105728', 'Int128')) < materialize(toDecimal32('1.5', 2));
SELECT materialize(CAST('-57896044618658097711785492504343953926634992332820282019728792003956564819968', 'Int256')) != materialize(toDecimal64('1.5', 4));

-- The same extreme values in the reverse operand order do overflow: with the Decimal on the left,
-- DecimalComparison scales the wide integer up to the Decimal scale (the scale_right instantiation),
-- which is a distinct path from the wide-int-on-the-left (scale_left) direction above that compares
-- them without overflow.
SELECT '-- the reverse operand order overflows during scale conversion';
{{ cmp_throws("toDecimal32('1.5', 2)", '>', "CAST('-170141183460469231731687303715884105728', 'Int128')", 'DECIMAL_OVERFLOW') }}
{{ cmp_throws("toDecimal64('1.5', 4)", '!=', "CAST('-57896044618658097711785492504343953926634992332820282019728792003956564819968', 'Int256')", 'DECIMAL_OVERFLOW') }}

SELECT '-- division by zero in every width direction';
{{ fn_throws('intDiv', 'toUInt256(1)', 'toUInt8(0)', 'ILLEGAL_DIVISION') }}
{{ fn_throws('intDiv', 'toUInt8(1)', 'toUInt256(0)', 'ILLEGAL_DIVISION') }}
{{ fn_throws('intDiv', 'toInt256(1)', 'toInt256(0)', 'ILLEGAL_DIVISION') }}
{{ fn_throws('modulo', 'toInt256(-1)', 'toUInt64(0)', 'ILLEGAL_DIVISION') }}
{{ fn_throws('modulo', 'toUInt64(1)', 'toUInt256(0)', 'ILLEGAL_DIVISION') }}
{{ fn_throws('positiveModulo', 'toInt128(-1)', 'toUInt32(0)', 'ILLEGAL_DIVISION') }}
{{ fn_throws('moduloLegacy', 'toUInt256(1)', 'toUInt8(0)', 'ILLEGAL_DIVISION') }}
